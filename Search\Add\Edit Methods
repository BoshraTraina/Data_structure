#include <iostream>
using namespace std;

const int size = 50;

int search(int a[], int n, int num) {
    for (int i = 0; i < n; i++) {
        if (a[i] == num) return i;
    }
    return -1;
}

void edit(int a[], int n, int index, int num) {
    if (search(a, n, num) == -1) {
        if (index < n) {
            a[index] = num;

            if (index < n - 1 && a[index] > a[index + 1]) {
                for (int i = index; i < n - 1; i++) {
                    if (a[i] > a[i + 1])
                        swap(a[i], a[i + 1]);
                    else break;
                }
            } else if (index > 0 && a[index] < a[index - 1]) {
                for (int i = index; i > 0; i--) {
                    if (a[i] < a[i - 1])
                        swap(a[i], a[i - 1]);
                    else break;
                }
            }
        } else
            cout << "wrong index ";
    } else
        cout << "the element is found";
}

void add(int a[], int &n, int num) {
    if (n < size) {
        if (search(a, n, num) == -1) {
            a[n] = num;
            n++;
            for (int i = n - 1; i > 0; i--) {
                if (a[i] < a[i - 1])
                    swap(a[i], a[i - 1]);
                else break;
            }
        } else
            cout << "the element is found";
    } else
        cout << "the array is full";
}

int main() {
    int a[size] = {1, 3, 5, 7, 9};
    int n = 5;

    for (int i = 0; i < n; i++)
        cout << a[i] << " ";

    cout << endl;

    add(a, n, 6);

    for (int i = 0; i < n; i++)
        cout << a[i] << " ";

    cout << endl;

    edit(a, n, 2, 4);

    for (int i = 0; i < n; i++)
        cout << a[i] << " ";

    cout << endl;

    int pos = search(a, n, 7);

    if (pos != -1)
        cout << pos;
    else
        cout << "Not found";

    return 0;
}
