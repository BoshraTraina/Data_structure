#include <iostream>
#include <string>

using namespace std;
const int size=50;
void push(char s[], int &top, char val) {
    s[++top] = val;
}

void pop(int &top) {
    top--;
}
void push(int s[], int &top, int val) {
    s[++top] = val;
}

int ret(int s[], int top) {
    return s[top];
}


char ret(char s[], int top) {
    return s[top];
}

bool isfull(int top) {
    return top == size - 1;
}

bool isempty(int top) {
    return top == -1;
}

bool isOP(char exp){
    return (exp=='*'||exp=='+'||exp=='-'||exp=='/');
}

int isBS(char exp){
    if(exp=='+'||exp=='-') return 1;
    else if(exp=='*'||exp=='/') return 2;
    return 0;
}



string convertToPostfix(string exp){

          char s[size];
          int top=-1;
    string output="";
    for(int i=0; exp[i]!='\0'; i++){
        if (exp[i] == ' ') continue;
        else if (isdigit(exp[i]) || isalpha(exp[i])) {
            output += exp[i];
        }
         else if (exp[i] == '(') {
        push(s, top, exp[i]);

    }else if (exp[i] == ')') {
        while (!isempty(top) && ret(s, top) != '(') {
            output += ret(s, top);
            pop(top);
        }
        pop(top);
    }


        else if (isOP(exp[i])&& top==-1) {
          push(s,top,exp[i]);
        }
        else if (!isfull(top)&& isBS(exp[i])>isBS(ret(s,top))) {
            push(s,top,exp[i]);

        }
        else{
            while(isBS(exp[i])<=isBS(ret(s,top))){
                output += ret(s,top);
                pop(top);
            }
        push(s,top,exp[i]);
        }
    }
   while (!isempty(top)) {
    output += ret(s, top);
    pop(top);
}

    return output;
}

int eval(string post){
    int s[size],top=-1;
    for(int i=0;post[i]!='\0';i++){

        if(isdigit(post[i])&&!isfull(top)){
         int val = post[i] - '0';
            push(s,top,val);

        }else if(isOP(post[i])){
         int op2=ret(s,top);
         pop(top);
         int op1=ret(s,top);
         pop(top);
  int result = 0;
          switch (post[i]) {
                case '+': result = op1 + op2; break;
                case '-': result = op1 - op2; break;
                case '*': result = op1 * op2; break;
                case '/':
                    if (op2 == 0) {
                        cout << "dividing by zero" << endl;
                        return 0;
                    }
                    result = op1 / op2;
                    break;
            }
            s[++top] = result;

        }
return ret(s,top);
    }


}

int main(){
    string exp;
    cout << "enter the expression: ";
    cin >> exp;
    string output = convertToPostfix(exp);
    cout << "the postfix is " << output<<endl;
    cout<<"the evaluation of expression is "<<eval(output);


    return 0;
}

