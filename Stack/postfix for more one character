#include <iostream>
#include <cstring>
#include <cctype>
using namespace std;

const int size = 50;
const int size2 = 20;

struct Stack {
    string arr[size];
    int top = -1;

    void push(string val) {
        if (!full())
            arr[++top] = val;
    }

    void pop() {
        if (!isempty())
            top--;
    }

    string ret() {
        return arr[top];
    }

    bool full() {
        return top == size - 1;
    }

    bool isempty() {
        return top == -1;
    }
};

int precedence(string op) {
    if (op == "*" || op == "/")
        return 2;
    if (op == "+" || op == "-")
        return 1;
    return 0;
}

bool isOperator(string s) {
    return (s == "+" || s == "-" || s == "*" || s == "/");
}

int main() {
    char infix[size];
    char edit[size][size2];

    cout << "Enter infix expression: ";
    cin.getline(infix, size);

    int c = 0;
    for (int i = 0; infix[i] != '\0'; i++) {
        if (isalpha(infix[i]) || isdigit(infix[i])) {
            int j = 0;
            while (isalpha(infix[i]) || isdigit(infix[i])) {
                edit[c][j++] = infix[i++];
            }
            edit[c][j] = '\0';
            c++;
            i--;
        } else if (infix[i] != ' ') {
            edit[c][0] = infix[i];
            edit[c][1] = '\0';
            c++;
        }
    }

    Stack s;
    string postfix[size];
    int p = 0;

    for (int i = 0; i < c; i++) {
        string token = edit[i];

        if (isalnum(token[0])) {
            postfix[p++] = token;
        }
        else if (token == "(") {
            s.push(token);
        }
        else if (token == ")") {
            while (!s.isempty() && s.ret() != "(") {
                postfix[p++] = s.ret();
                s.pop();
            }
            s.pop();
        }
        else if (isOperator(token)) {
            while (!s.isempty() && precedence(s.ret()) >= precedence(token)) {
                postfix[p++] = s.ret();
                s.pop();
            }
            s.push(token);
        }
    }

    while (!s.isempty()) {
        postfix[p++] = s.ret();
        s.pop();
    }

    cout << "Postfix expression: ";
    for (int i = 0; i < p; i++) {
        cout << postfix[i] << " ";
    }
    cout << endl;

    return 0;
}

