#include <iostream>
using namespace std;

const int size = 5;

int full(int f, int l)
{
    if ((f == 0 && l == size - 1) || (f == l + 1))
        return 1;
    else
        return 0;
}

int empty(int f)
{
    return (f == -1);
}

void enqueue(int q[], int& f, int& l, int val)
{
    if (!full(f, l))
    {
        if (l == size - 1 || l == -1)
            l = 0;
        else
            l++;

        q[l] = val;

        if (f == -1)
            f = 0;
    }
    else
        cout << "Full queue" << endl;
}

void dequeue(int& f, int& l)
{
    if (!empty(f))
    {
        if (f == l)
            f = l = -1;
        else if (f == size - 1)
            f = 0;
        else
            f++;
    }
    else
        cout << "Empty queue" << endl;
}

int retrieve(int q[], int f)
{
    if (!empty(f))
        return q[f];
    else
    {
        cout << "Empty queue" << endl;
        return -1;
    }
}

void print(int q[], int f, int l)
{
    if (empty(f))
    {
        cout << "Queue is empty" << endl;
        return;
    }

    cout << "Queue elements: ";

    int i = f;
    while (true)
    {
        cout << q[i] << " ";
        if (i == l)
            break;

        if (i == size - 1)
            i = 0;
        else
            i++;
    }

    cout << endl;
}

int main()
{
    int q[size], f = -1, l = -1;

    enqueue(q, f, l, 1);
    enqueue(q, f, l, 2);
    enqueue(q, f, l, 3);
    enqueue(q, f, l, 4);
    enqueue(q, f, l, 5);

    print(q, f, l);

    dequeue(f, l);
    dequeue(f, l);

    enqueue(q, f, l, 6);
    enqueue(q, f, l, 7);

    print(q, f, l);

    cout << retrieve(q, f);

    return 0;
}
